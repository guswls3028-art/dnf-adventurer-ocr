{
  "name": "dnf-adventurer-ocr",
  "version": "0.1.0",
  "private": true,
  "description": "DNF Mobile adventurer verification and character-list OCR helper using Gemini API.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "dnf-adventurer-ocr": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "ocr": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
